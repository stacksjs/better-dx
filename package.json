{
  "name": "better-dx",
  "type": "module",
  "version": "0.2.16",
  "description": "All the development dependencies you need.",
  "author": "Chris Breuer <chris@stacksjs.org>",
  "license": "MIT",
  "homepage": "https://github.com/stacksjs/better-dx#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stacksjs/better-dx.git"
  },
  "bugs": {
    "url": "https://github.com/stacksjs/better-dx/issues"
  },
  "keywords": [
    "typescript",
    "development",
    "kit",
    "bun",
    "package"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./*": {
      "import": "./dist/*"
    }
  },
  "module": "./dist/src/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "README.md",
    "dist"
  ],
  "scripts": {
    "build": "bun --bun build.ts && bun run compile",
    "compile": "bun build ./bin/cli.ts --compile --minify --outfile bin/dx",
    "compile:all": "bun run compile:linux-x64 && bun run compile:linux-arm64 && bun run compile:windows-x64 && bun run compile:darwin-x64 && bun run compile:darwin-arm64",
    "compile:linux-x64": "bun build ./bin/cli.ts --compile --minify --target=bun-linux-x64 --outfile bin/dx-linux-x64",
    "compile:linux-arm64": "bun build ./bin/cli.ts --compile --minify --target=bun-linux-arm64 --outfile bin/dx-linux-arm64",
    "compile:windows-x64": "bun build ./bin/cli.ts --compile --minify --target=bun-windows-x64 --outfile bin/dx-windows-x64.exe",
    "compile:darwin-x64": "bun build ./bin/cli.ts --compile --minify --target=bun-darwin-x64 --outfile bin/dx-darwin-x64",
    "compile:darwin-arm64": "bun build ./bin/cli.ts --compile --minify --target=bun-darwin-arm64 --outfile bin/dx-darwin-arm64",
    "zip": "bun run zip:all",
    "zip:all": "bun run zip:linux-x64 && bun run zip:linux-arm64 && bun run zip:windows-x64 && bun run zip:darwin-x64 && bun run zip:darwin-arm64",
    "zip:linux-x64": "zip -j bin/dx-linux-x64.zip bin/dx-linux-x64",
    "zip:linux-arm64": "zip -j bin/dx-linux-arm64.zip bin/dx-linux-arm64",
    "zip:windows-x64": "zip -j bin/dx-windows-x64.zip bin/dx-windows-x64.exe",
    "zip:darwin-x64": "zip -j bin/dx-darwin-x64.zip bin/dx-darwin-x64",
    "zip:darwin-arm64": "zip -j bin/dx-darwin-arm64.zip bin/dx-darwin-arm64",
    "fresh": "bun x rimraf node_modules/ bun.lock && bun i",
    "prepublishOnly": "bun --bun run build && bun run compile:all && bun run zip",
    "test": "bun test",
    "lint": "bun x --bun pickier .",
    "lint:fix": "bun x --bun pickier . --fix",
    "format": "bun x --bun pickier . --format",
    "format:fix": "bun x --bun pickier . --format --write",
    "changelog": "bun x logsmith --verbose",
    "changelog:generate": "bun x logsmith --output CHANGELOG.md",
    "release": "bun x --bun bumpx prompt --recursive",
    "release:patch": "bun x --bun bumpx patch --recursive --yes",
    "publish:patch": "bun x --bun bumpx patch --recursive --yes",
    "dev:docs": "bun --bun bunpress dev docs",
    "build:docs": "bun --bun bunpress build docs",
    "preview:docs": "bun --bun bunpress preview docs",
    "typecheck": "bun --bun tsc --noEmit"
  },
  "dependencies": {
    "@stacksjs/clapp": "^0.2.6",
    "@stacksjs/bumpx": "^0.2.5",
    "@stacksjs/bunpress": "^0.1.4",
    "@stacksjs/clarity": "^0.3.28",
    "@stacksjs/gitlint": "^0.1.5",
    "@stacksjs/logsmith": "^0.2.1",
    "@types/bun": "^1.3.13",
    "buddy-bot": "^0.9.17",
    "bun-git-hooks": "^0.3.2",
    "bun-plugin-dtsx": "^0.10.2",
    "bunfig": "^0.15.11",
    "pickier": "^0.1.28",
    "ts-error-handling": "^0.1.1",
    "typescript": "^7.0.2"
  },
  "overrides": {
    "typescript": "^7.0.2"
  },
  "git-hooks": {
    "pre-commit": {
      "staged-lint": {
        "*.{js,ts,json,yaml,yml,md}": "bunx --bun pickier lint --fix"
      }
    },
    "commit-msg": "bunx gitlint --edit .git/COMMIT_EDITMSG"
  }
}
